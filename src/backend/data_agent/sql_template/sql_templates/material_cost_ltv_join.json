{
  "template_name": "material_cost_ltv_join",
  "name": "素材成本与 LTV 联合分析",
  "description": "用于将 dws_v4_ad_cost_daily 的消耗点击与 ads_material_daily 的素材新增、收入、LTV、留存联合，评估素材投放质量。",
  "intent": "data_query",
  "analysis_types": [
    "join",
    "material",
    "cost",
    "ltv",
    "roi",
    "complex"
  ],
  "source_tables": [
    "dws_v4_ad_cost_daily",
    "ads_material_daily"
  ],
  "required_slots": [
    "metrics",
    "time"
  ],
  "optional_slots": [
    "dimensions",
    "filters",
    "having",
    "order_by",
    "limit"
  ],
  "supported_metrics": [
    "spend",
    "impressions",
    "clicks",
    "platform_conversions",
    "game_new_user_cnt",
    "pay_user_cnt",
    "revenue",
    "roi_d0",
    "ltv_7d_per_user",
    "ltv_30d_per_user",
    "retention_d7",
    "cum_pay_rate_d30"
  ],
  "supported_dimensions": [
    "date",
    "parent_app",
    "app",

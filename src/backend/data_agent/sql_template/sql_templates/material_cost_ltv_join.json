  ],
  "related_questions": [
    "哪些素材适合继续加预算？",
    "最近 7 天新增多但 LTV 低的素材有哪些？",
    "素材消耗和 D30 LTV 是否匹配？"
  ],
  "unsupported_cases": [],
  "sql_params": [
    "cost_group_fields",
    "material_group_fields",
    "start_date",
    "end_date",
    "cost_where_filters",
    "material_where_filters",
    "join_conditions",
    "select_join_dimensions",
    "having",
    "order_by",
    "limit"
  ],
  "template_sql_lines": [
    "WITH c AS (",
    "  SELECT {{cost_group_fields}},",
    "         SUM(cost_amt) / 100 AS spend,",
    "         SUM(impression_cnt) AS impressions,",
    "         SUM(click_cnt) AS clicks,",
    "         SUM(platform_convert_cnt) AS platform_conversions",
    "  FROM dws_v4_ad_cost_daily",
    "  WHERE stat_date BETWEEN {{start_date}} AND {{end_date}}",
    "    {{cost_where_filters}}",
    "  GROUP BY {{cost_group_by_fields}}",
    "), m AS (",
    "  SELECT {{material_group_fields}},",
    "         SUM(game_new_user_cnt) AS game_new_user_cnt,",
    "         SUM(pay_user_cnt) AS pay_user_cnt,",
    "         SUM(pay_amt_sum) / 100 AS revenue,",
    "         SUM(ltv_7d) / 100 / NULLIF(SUM(game_new_user_cnt), 0) AS ltv_7d_per_user,",
    "         SUM(ltv_30d) / 100 / NULLIF(SUM(game_new_user_cnt), 0) AS ltv_30d_per_user,",
    "         SUM(retain_d7_cnt) / NULLIF(SUM(game_new_user_cnt), 0) AS retention_d7,",
    "         SUM(cumulative_pay_user_d30) / NULLIF(SUM(game_new_user_cnt), 0) AS cum_pay_rate_d30",
    "  FROM ads_material_daily",
    "  WHERE stat_date BETWEEN {{start_date}} AND {{end_date}}",
    "    {{material_where_filters}}",
    "  GROUP BY {{material_group_by_fields}}",
    ")",
    "SELECT {{select_join_dimensions}},",
    "       c.spend, c.impressions, c.clicks, c.platform_conversions,",
    "       m.game_new_user_cnt, m.pay_user_cnt, m.revenue,",
    "       m.ltv_7d_per_user, m.ltv_30d_per_user, m.retention_d7, m.cum_pay_rate_d30,",
    "       m.revenue / NULLIF(c.spend, 0) AS roi_d0,",
    "       (m.ltv_30d_per_user * m.game_new_user_cnt) / NULLIF(c.spend, 0) AS d30_roi_estimated",
    "FROM c",
    "JOIN m ON {{join_conditions}}",
    "{{having_clause}}",
    "{{order_by_clause}}",
    "{{limit_clause}}"
  ],
  "compiler_notes": [
    "成本表没有 material_type/ad_link_id 时，不能把这些字段作为 join key；它们只能来自 ads_material_daily。",
    "roi_d0 是跨表派生指标，模板输出别名固定为 roi_d0，对应 metric_definitions.roi_d0.expr_by_template.material_cost_ltv_join。",
    "模板描述字段用于召回和编译约束；真正 SQL 生成仍必须通过安全校验和字段存在性校验。"
  ],
  "priority": 66,
  "business_description": "素材成本与 LTV 联合分析。用于将 dws_v4_ad_cost_daily 的消耗点击与 ads_material_daily 的素材新增、收入、LTV、留存联合，评估素材投放质量。 来源表：dws_v4_ad_cost_daily、ads_material_daily；分析类型：join、material、cost、ltv、roi、complex；支持 12 个指标和 13 个维度。",
  "selection_guidance": "当用户问题需要join、material、cost、ltv、roi、complex，且业务范围落在 dws_v4_ad_cost_daily、ads_material_daily 时优先选择该模板。典型问题：哪些素材适合继续加预算？；最近 7 天新增多但 LTV 低的素材有哪些？；素材消耗和 D30 LTV 是否匹配？。",
  "slot_guidance": "必填槽位：metrics、time；可选槽位：dimensions、filters、having、order_by、limit。缺少 time 时应向用户澄清或采用系统默认时间范围；filters/having/order_by/limit 只能使用支持的字段和指标。",
  "output_contract": "输出列应包含用户请求的维度列和指标列；指标别名必须与 metric_id 保持一致，模板级派生指标必须使用 metric_definitions 中 expr_by_template 对应的别名。",
  "compiler_guidance": "编译时从 supported_dimensions 中选择 group/filter 字段，从 supported_metrics 中选择 select 指标；所有 source_tables 必须来自当前 schema。"
}

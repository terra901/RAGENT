# 问数 Data Agent 配置示例
# 复制为 .env 后按环境修改。默认端口使用 RAGENT 独立容器，不占用 Discord-bot 容器。

DA_LLM_BASE_URL=https://api.openai.com/v1
DA_LLM_API_KEY=<your-api-key-here>
DA_LLM_MODEL=gpt-4o
DA_LLM_TEMPERATURE=0.0
DA_LLM_MAX_TOKENS=2048

DA_DB_URL=mysql+asyncmy://root:140617@127.0.0.1:3307/RAGENT?charset=utf8mb4
DA_DB_READ_ONLY=true

DA_SAFETY_MAX_ROWS=100
DA_SAFETY_QUERY_TIMEOUT=30.0
DA_SAFETY_MAX_TOKENS_PER_REQUEST=0
DA_MASKING_MODE=mask

DA_CORS_ORIGINS=
DA_CORS_ALLOW_CREDENTIALS=false
DA_RATE_LIMIT_PER_MINUTE=60
DA_API_KEY=

DA_JWT_SECRET=ragent-local-dev-secret-change-me
DA_JWT_ISSUER=ragent-data-agent
DA_BOOTSTRAP_ADMIN_ENABLED=true
DA_BOOTSTRAP_ADMIN_EMAIL=admin@ragent.local
DA_BOOTSTRAP_ADMIN_PASSWORD=140617
DA_BOOTSTRAP_ADMIN_NAME=RAGENT 管理员
DA_BOOTSTRAP_ADMIN_MODULES=chat,data_query,schema,sql_template,chart,trace,feedback,memory,admin,model_management,observability,queue

DA_SESSION_TTL_SECONDS=3600
DA_SESSION_MAX_COUNT=1000
DA_SESSION_HISTORY_TURNS=3

DA_SCHEMA_RECALL_THRESHOLD=8
DA_SCHEMA_RECALL_TOP_K=8
DA_SCHEMA_WITH_COUNT=true
DA_HEALTH_VERBOSE=true

DA_RESULT_CACHE_TTL_SECONDS=300
DA_RESULT_CACHE_MAX_SIZE=200

DA_EMBEDDINGS_ENABLED=false
DA_EMBEDDINGS_MODEL=BAAI/bge-small-zh-v1.5
DA_RAG_ENABLED=true
DA_VEC_DB_PATH=./data/memory.db
DA_MEMORY_ENABLED=true

DA_STREAM_LLM_TOKENS=true
DA_CHART_ENABLED=true
DA_CHART_MIN_ROWS=2
DA_CHART_MAX_ROWS=200

DA_FEEDBACK_ENABLED=true
DA_FEEDBACK_DB_PATH=./data/feedback.db
DA_FEEDBACK_AUTO_APPROVE=false
DA_FEEDBACK_RECALL_TOP_K=3

DA_REDIS_URL=redis://:140617@127.0.0.1:6380/0
DA_REDIS_KEY_PREFIX=data-agent

DA_RABBITMQ_URL=amqp://ragent:140617@127.0.0.1:5673/ragent
DA_CELERY_BROKER_URL=amqp://ragent:140617@127.0.0.1:5673/ragent
DA_CELERY_RESULT_BACKEND=

DA_AGENT_RUNTIME_FACTORY=data_agent.agent.runtime:build_agent_runtime

DA_TRACING_ENABLED=true
DA_TRACE_DB_PATH=./data/trace.db
DA_TRACE_RETENTION_DAYS=7
DA_TRACE_SAMPLE_RATE=1.0
DA_TRACE_API_ENABLED=false
DA_OTEL_ENABLED=true
DA_OTEL_SERVICE_NAME=ragent-agent
DA_LANGFUSE_ENABLED=false
DA_LANGFUSE_PUBLIC_KEY=
DA_LANGFUSE_SECRET_KEY=
DA_LANGFUSE_HOST=http://127.0.0.1:3000
DA_LANGFUSE_ENVIRONMENT=local

DA_MODEL_KEY_SECRET=ragent-model-key-secret-140617

DA_LOG_LEVEL=INFO
DA_HOST=127.0.0.1
DA_PORT=8000
